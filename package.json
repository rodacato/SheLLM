{
  "name": "shellm",
  "version": "0.2.0",
  "license": "MIT",
  "description": "Your LLM services — unified as a REST API",
  "main": "src/server.js",
  "bin": {
    "shellm": "src/cli.js"
  },
  "scripts": {
    "version": "node scripts/changelog.js && git add CHANGELOG.md",
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "check:env": "node scripts/check-env.js",
    "test": "node --experimental-test-module-mocks --test 'test/*.test.js' 'test/**/*.test.js'",
    "test:e2e": "node --test --test-timeout 120000 test/e2e/*.e2e.js",
    "smoke": "node test/smoke.mjs",
    "docs:build": "redocly bundle docs/api/openapi.yaml --output docs/api/bundled.json --ext json",
    "docs:preview": "redocly preview docs/api/openapi.yaml",
    "docs:lint": "redocly lint docs/api/openapi.yaml",
    "favicons": "node scripts/generate-favicons.js",
    "screenshots": "node scripts/screenshots.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@redocly/cli": "^2.24.1",
    "puppeteer": "^24.40.0",
    "sharp": "^0.34.5",
    "supertest": "^7.1.0"
  },
  "engines": {
    "node": ">=22"
  }
}
