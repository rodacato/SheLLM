{
  "name": "shellm",
  "version": "0.4.1",
  "license": "MIT",
  "description": "Your LLM services — unified as a REST API",
  "main": "src/server.js",
  "bin": {
    "shellm": "src/cli.js"
  },
  "scripts": {
    "prepare": "git config core.hooksPath scripts 2>/dev/null || true",
    "version": "node scripts/release-changelog.js && sed -i \"s/v[0-9]*\\.[0-9]*\\.[0-9]*/v$npm_package_version/\" site/index.html && git add CHANGELOG.md site/index.html",
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "seed": "node scripts/seed.js",
    "migrate": "node -e \"require('./src/db').initDb()\"",
    "check:env": "node scripts/setup/check-env.js",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint --fix src/ test/",
    "test": "node --experimental-test-module-mocks --test 'test/*.test.js' 'test/**/*.test.js'",
    "test:e2e": "node --test --test-timeout 120000 test/e2e/*.e2e.js",
    "smoke": "node test/smoke.mjs",
    "audit:security": "npm audit --audit-level=high",
    "docs:build": "redocly bundle docs/api/openapi.yaml --output docs/api/bundled.json --ext json",
    "docs:preview": "redocly preview docs/api/openapi.yaml",
    "docs:lint": "redocly lint docs/api/openapi.yaml",
    "release:favicons": "node scripts/release-favicons.js",
    "release:screenshots": "node scripts/release-screenshots.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@redocly/cli": "^2.24.1",
    "eslint": "^9.39.4",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "supertest": "^7.1.0"
  },
  "engines": {
    "node": ">=22"
  }
}
